{
	"name": "vue-mount-plugin",
	"description": "A simple and easy to use vue instance extension plugin that supports vue2.0 and vue3.0",
	"type": "module",
	"version": "4.0.0-beta.6",
	"packageManager": "pnpm@8.9.0",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"unpkg": "dist/index.iife.min.js",
	"jsdelivr": "dist/index.iife.min.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs"
		},
		"./*": "./*"
	},
	"directories": {
		"dist": "dist",
		"src": "src"
	},
	"files": [
		"dist",
		"typings"
	],
	"scripts": {
		"build": "run-s clean build:{bundle,types,es5}",
		"build:bundle": "tsx scripts/build",
		"build:es5": "cross-env BABEL_ENV=es5 pnpm build:bundle",
		"build:types": "tsc -p src/tsconfig.json && pnpm roll-types",
		"build:docs": "vitepress build docs",
		"docs:dev": "vitepress dev docs",
		"docs:preview": "vitepress preview docs",
		"deploy": "sh scripts/deploy.sh",
		"roll-types": "api-extractor run && rm-all temp",
		"watch": "pnpm build:bundle -w",
		"pub": "tsx scripts/publish",
		"unpub": "tsx scripts/unpublish",
		"sync": "tsx scripts/sync",
		"workflow:publish-test": "zx scripts/workflow.mjs",
		"clean": "rm-all dist es lib",
		"dist": "run-s lint:fix build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:2": "vue-demi-switch 2 vue2 && vitest run",
		"test:3": "vue-demi-switch 3 && vitest run",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"dependencies": {
		"js-cool": "^5.23.2",
		"tslib": "^2.8.1",
		"vue-demi": "^0.14.10"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-typescript": "^7.28.5",
		"@eslint-sets/eslint-config": "^6.2.0",
		"@microsoft/api-extractor": "^7.57.7",
		"@rollup/plugin-alias": "^5.1.1",
		"@rollup/plugin-babel": "^7.0.0",
		"@rollup/plugin-commonjs": "^28.0.9",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^22.19.15",
		"@vitest/coverage-v8": "^4.1.0",
		"chalk": "^5.6.2",
		"core-js": "^3.49.0",
		"cross-env": "^7.0.3",
		"esbuild": "^0.27.4",
		"eslint": "^9.39.4",
		"fast-glob": "^3.3.3",
		"jsdom": "^29.0.1",
		"load-yml": "^1.4.0",
		"npm-run-all": "^4.1.5",
		"reinstaller": "^3.0.2",
		"rm-all": "^1.1.1",
		"rollup": "^4.59.1",
		"rollup-plugin-cleanup": "^3.2.1",
		"rollup-plugin-esbuild": "^6.2.1",
		"rollup-plugin-filesize": "^10.0.0",
		"rollup-plugin-inject-code": "^1.1.0",
		"rollup-plugin-visualizer": "^5.14.0",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.17",
		"typedoc-plugin-markdown": "^4.11.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.0",
		"vue": "^3.5.30",
		"vue2": "npm:vue@^2.7.16",
		"zx": "^8.8.5"
	},
	"peerDependencies": {
		"@vue/composition-api": ">=1.0.0",
		"js-cool": ">= 2",
		"vue": "^2.0.0 || >=3.0.0"
	},
	"peerDependenciesMeta": {
		"@vue/composition-api": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=14.14.0"
	},
	"sideEffects": false,
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"tslib",
				"webpack"
			],
			"allowedVersions": {
				"rollup": ">=3.20.0",
				"eslint": "^9.0.0"
			}
		}
	},
	"keywords": [
		"vue",
		"vue2.0",
		"vue3.0",
		"vue-extend",
		"mount-plugin",
		"vue-plugin",
		"vue-mount-plugin",
		"saqqdy"
	],
	"license": "MIT",
	"author": "saqqdy <https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/vue-mount-plugin#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/vue-mount-plugin/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/vue-mount-plugin.git"
	},
	"funding": "https://github.com/sponsors/saqqdy",
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	}
}
